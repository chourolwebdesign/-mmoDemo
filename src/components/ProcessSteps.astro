---
interface Step {
  title: string;
  text: string;
}

interface Props {
  steps?: Step[];
}

const defaultSteps: Step[] = [
  {
    title: "Erstgespräch & Bewertung",
    text: "Wir besichtigen Ihre Immobilie vor Ort und ermitteln den erzielbaren Marktpreis auf Basis realer Vergleichsdaten aus dem Gutachterausschuss.",
  },
  {
    title: "Vermarktung",
    text: "Professionelles Exposé mit Fotos, Energieausweis und Grundriss — Ausspielung über Portale sowie unsere eigene, geprüfte Käuferkartei.",
  },
  {
    title: "Besichtigungen & Bonitätsprüfung",
    text: "Wir übernehmen die Terminorganisation, begleiten jede Besichtigung persönlich und prüfen die Bonität ernsthafter Interessenten vorab.",
  },
  {
    title: "Notartermin & Übergabe",
    text: "Von der Preisverhandlung über die notarielle Beurkundung bis zum Übergabeprotokoll stehen wir Ihnen bis zum Abschluss zur Seite.",
  },
];

const { steps = defaultSteps } = Astro.props;
---

<div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
  {steps.map((step, i) => (
    <div class="relative rounded-2xl border border-line bg-white p-6">
      <span class="font-display text-3xl text-brass-soft">{String(i + 1).padStart(2, "0")}</span>
      <h3 class="mt-3 font-display text-lg text-ink">{step.title}</h3>
      <p class="mt-2 text-sm leading-relaxed text-slate">{step.text}</p>
    </div>
  ))}
</div>

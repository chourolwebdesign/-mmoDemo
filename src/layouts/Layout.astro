---
import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import CookieConsent from "../components/CookieConsent.astro";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  image?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown>[];
}

const { title, description, image, noindex, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#f7f5f1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,500&family=Hanken+Grotesk:wght@400;500;600;700&display=swap"
    />
    <SEOHead title={title} description={description} image={image} noindex={noindex} jsonLd={jsonLd} />
  </head>
  <body id="top">
    <a href="#main" class="skip-link">Zum Inhalt springen</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <CookieConsent />
  </body>
</html>

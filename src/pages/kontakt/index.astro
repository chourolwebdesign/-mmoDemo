---
import Layout from "../../layouts/Layout.astro";
import MapsConsent from "../../components/MapsConsent.astro";
import { site, regionen } from "../../data/site";

const direktRows = [
  { label: "Telefon", value: site.phoneDisplay, href: `tel:${site.phone.replace(/\s/g, "")}`, icon: "M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z" },
  { label: "E-Mail", value: site.email, href: `mailto:${site.email}`, icon: "M4 4h16a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm0 3 8 6 8-6" },
  { label: "Büro", value: `${site.street}, ${site.zip} ${site.city}`, icon: "M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Zm-8 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6Z" },
  { label: "Öffnungszeiten", value: site.hours, icon: "M12 22a10 10 0 1 0 0-20 10 10 0 0 0 0 20Zm0-16v6l4 2" },
  { label: "Termine", value: site.hoursNote, icon: "M8 2v4M16 2v4M3 8h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" },
];
---

<Layout
  title={`Kontakt | ${site.name}`}
  description={`Kontaktieren Sie ${site.name} in Montabaur — telefonisch, per E-Mail oder über unser Kontaktformular. Mo–Fr 9–18 Uhr, Sa 10–14 Uhr, weitere Termine nach Absprache.`}
>
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="grid gap-8 lg:grid-cols-[160px_1fr]">
      <p class="eyebrow pt-3 lg:border-t lg:border-brass lg:pt-4">Kontakt</p>
      <div>
        <h1 class="max-w-2xl font-display text-4xl leading-[1.12] text-ink sm:text-5xl">
          Ein Anruf. <em class="font-normal text-slate">Ein Ansprechpartner.</em>
          Ein klarer nächster Schritt.
        </h1>
        <p class="mt-5 max-w-xl text-slate leading-relaxed">
          Ob Bewertung, Verkauf, Vermietung oder Verwaltung — schreiben Sie uns
          oder rufen Sie an. Wir melden uns persönlich zurück.
        </p>
      </div>
    </div>

    <div class="mt-14 grid gap-10 lg:grid-cols-[1fr_420px]">
      <div class="border border-line bg-white p-6 sm:p-8">
        <h2 class="font-display text-2xl text-ink">Nachricht senden</h2>
        <p class="mt-1 text-sm text-slate">
          Wir behandeln Ihre Anfrage vertraulich und melden uns zeitnah zurück.
        </p>
        <form id="kontakt-form" class="mt-8 grid gap-5 sm:grid-cols-2">
          <input type="text" name="_honeypot" class="hidden" tabindex="-1" autocomplete="off" />

          <div class="flex flex-col gap-1.5">
            <label for="k-vorname" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">Vorname</label>
            <input id="k-vorname" name="Vorname" type="text" autocomplete="given-name" class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm focus:border-brass focus:ring-0" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="k-nachname" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">Nachname *</label>
            <input id="k-nachname" name="Nachname" type="text" required autocomplete="family-name" class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm focus:border-brass focus:ring-0" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="k-telefon" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">Telefon</label>
            <input id="k-telefon" name="Telefon" type="tel" autocomplete="tel" class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm focus:border-brass focus:ring-0" />
          </div>
          <div class="flex flex-col gap-1.5">
            <label for="k-email" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">E-Mail-Adresse *</label>
            <input id="k-email" name="E-Mail" type="email" required autocomplete="email" class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm focus:border-brass focus:ring-0" />
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label for="k-anliegen" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">Interesse an</label>
            <select id="k-anliegen" name="Interesse an" class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm focus:border-brass focus:ring-0">
              <option value="Beratung">Beratung</option>
              <option value="Wertermittlung">Wertermittlung</option>
              <option value="Immobilien">Immobilien</option>
              <option value="Hausverwaltung">Hausverwaltung</option>
              <option value="Objektpflege">Objektpflege</option>
            </select>
          </div>
          <div class="flex flex-col gap-1.5 sm:col-span-2">
            <label for="k-nachricht" class="text-[11px] font-semibold uppercase tracking-[0.16em] text-ink">Nachricht *</label>
            <textarea
              id="k-nachricht"
              name="Nachricht"
              required
              rows="4"
              placeholder="Erzählen Sie uns kurz von Ihrer Immobilie oder Ihrem Anliegen."
              class="border-0 border-b border-line bg-transparent px-0 py-2 text-sm placeholder:text-slate/50 focus:border-brass focus:ring-0"
            ></textarea>
          </div>

          <label class="flex items-start gap-2 text-sm text-ink sm:col-span-2">
            <input type="checkbox" name="Datenschutz akzeptiert" value="Ja" required class="mt-0.5 h-4 w-4 border-line" />
            <span>Ich habe die <a href="/datenschutz/" class="underline hover:text-brass-dark">Datenschutzerklärung</a> zur Kenntnis genommen und stimme der Verarbeitung meiner Daten zur Bearbeitung meiner Anfrage zu. *</span>
          </label>

          <div data-form-status class="hidden sm:col-span-2" aria-live="polite"></div>

          <div class="sm:col-span-2">
            <button type="submit" class="btn btn-dark">Nachricht senden</button>
          </div>
        </form>
      </div>

      <div class="space-y-8">
        <div>
          <p class="eyebrow">Direkt erreichbar</p>
          <ul class="mt-2 divide-y divide-line">
            {direktRows.map((row) => (
              <li class="flex items-start gap-4 py-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mt-1 shrink-0 text-brass" aria-hidden="true"><path d={row.icon} /></svg>
                <div>
                  <p class="text-[10px] font-semibold uppercase tracking-[0.18em] text-slate">{row.label}</p>
                  {row.href ? (
                    <a href={row.href} class="mt-0.5 block text-sm font-medium text-ink hover:text-brass-dark">{row.value}</a>
                  ) : (
                    <p class="mt-0.5 text-sm font-medium text-ink">{row.value}</p>
                  )}
                </div>
              </li>
            ))}
          </ul>
        </div>

        <blockquote class="border-l-2 border-brass pl-5 font-display text-xl leading-relaxed text-ink">
          „Bei uns landet Ihre Anfrage nicht in einem Ticketsystem, sondern bei
          einem Menschen, der Sie kennt."
          <footer class="mt-2 font-body text-xs not-italic text-slate">{site.name}</footer>
        </blockquote>

        <div class="border border-line bg-white p-6">
          <p class="eyebrow">Regionen</p>
          <p class="mt-3 text-sm leading-relaxed text-slate">
            {regionen.join(" · ")}
          </p>
        </div>

        <MapsConsent ort={site.city} plz={site.zip} />
      </div>
    </div>
  </section>
</Layout>

<script>
  import { wireForm } from "../../lib/form-handler";
  wireForm("kontakt-form", "Neue Kontaktanfrage");
</script>

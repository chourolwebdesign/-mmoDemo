---
const pillars = [
  { title: "Inhabergeführt", text: "Kurze Wege, klare Entscheidungen" },
  { title: "Regional verwurzelt", text: "Westerwald · Koblenz · Limburg" },
  { title: "Diskret & ehrlich", text: "Auch in sensiblen Situationen" },
];
---

<section class="relative bg-ink">
  <div class="absolute inset-0 overflow-hidden">
    <img
      src="/images/site/hero.svg"
      alt="Schloss Montabaur über dem abendlichen Westerwald (Musterfoto)"
      class="h-full w-full object-cover opacity-80"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-ink/90 via-ink/55 to-ink/25"></div>
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-ink/90 to-transparent"></div>
  </div>

  <div class="relative mx-auto flex min-h-[82vh] max-w-6xl flex-col justify-between px-4 pb-10 pt-24 sm:px-6 sm:pt-32">
    <div class="max-w-2xl">
      <p class="eyebrow text-brass">Immobilien · Verwaltung · Objektservice</p>
      <h1 class="mt-4 font-display text-4xl leading-[1.08] text-white sm:text-5xl lg:text-6xl">
        Immobilien mit Vertrauen.<br />
        <em class="font-normal text-brass-soft">Persönlich betreut</em> aus Montabaur.
      </h1>
      <p class="mt-6 max-w-md text-base leading-relaxed text-white/85">
        Wir sind kein klassischer Makler. Wir sind Ihr langfristiger
        Ansprechpartner rund um Ihre Immobilie — vom ersten Gespräch bis weit
        über den Abschluss hinaus.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/kontakt/" class="btn btn-brass">
          Kostenlose Erstberatung <span aria-hidden="true">↗</span>
        </a>
        <a href="/leistungen/" class="btn btn-outline-light">
          Unsere Leistungen
        </a>
      </div>
    </div>

    <div class="mt-16 grid gap-6 border-t border-white/15 pt-8 sm:grid-cols-3">
      {pillars.map((p) => (
        <div>
          <p class="font-display text-lg text-white">{p.title}</p>
          <p class="mt-1 text-sm text-white/65">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

---
import { site } from "../data/site";
import MobileNav from "./MobileNav.astro";

const navLinks = [
  { href: "/immobilien/", label: "Immobilien" },
  { href: "/verkaufen/", label: "Verkaufen" },
  { href: "/wertermittlung/", label: "Wertermittlung" },
  { href: "/suchauftrag/", label: "Gesuche" },
  { href: "/ueber-uns/", label: "Über uns" },
  { href: "/kontakt/", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="shrink-0 whitespace-nowrap font-display text-xl font-medium tracking-tight text-ink sm:text-2xl">
      {site.shortName}
    </a>

    <nav class="hidden items-center gap-5 lg:flex xl:gap-7" aria-label="Hauptnavigation">
      {navLinks.map((link) => {
        const active = currentPath === link.href || (link.href !== "/" && currentPath.startsWith(link.href));
        return (
          <a
            href={link.href}
            class:list={[
              "whitespace-nowrap text-sm font-medium transition hover:text-brass",
              active ? "text-brass" : "text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a
        href={`https://wa.me/${site.whatsapp}`}
        target="_blank"
        rel="noopener noreferrer"
        class="hidden shrink-0 rounded-full border border-line p-2 text-ink transition hover:border-brass hover:text-brass sm:inline-flex"
        aria-label="WhatsApp Kontakt"
        title="WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12.04 2c-5.5 0-9.96 4.46-9.96 9.96 0 1.76.46 3.45 1.33 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.5 0 9.96-4.46 9.96-9.96S17.54 2 12.04 2Zm5.83 14.24c-.25.7-1.24 1.28-2.02 1.44-.55.11-1.26.2-3.66-.79-3.07-1.27-5.05-4.4-5.2-4.6-.15-.2-1.24-1.65-1.24-3.15 0-1.5.78-2.24 1.06-2.54.28-.31.6-.38.8-.38.2 0 .4 0 .58.01.19.01.44-.07.68.53.25.6.85 2.08.92 2.23.07.15.12.33.02.53-.1.2-.15.33-.3.5-.15.18-.31.4-.45.54-.15.15-.3.31-.13.61.17.3.76 1.26 1.63 2.04 1.12 1 2.06 1.31 2.36 1.46.3.15.48.13.65-.08.18-.2.75-.87.95-1.17.2-.3.4-.25.68-.15.28.1 1.76.83 2.06.98.3.15.5.23.58.36.07.13.07.75-.18 1.45Z"/>
        </svg>
      </a>
      <a
        href={`tel:${site.phone.replace(/\s/g, "")}`}
        class="hidden whitespace-nowrap text-sm font-medium text-ink transition hover:text-brass xl:inline-block"
      >
        {site.phoneDisplay}
      </a>
      <a
        href="/verkaufen/"
        class="hidden whitespace-nowrap rounded-full bg-ink px-4 py-2 text-sm font-medium text-white transition hover:bg-brass sm:inline-block"
      >
        Jetzt bewerten lassen
      </a>
      <button
        id="mobile-nav-open"
        type="button"
        class="inline-flex items-center justify-center rounded-full p-2 text-ink transition hover:text-brass lg:hidden"
        aria-label="Menü öffnen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<MobileNav />

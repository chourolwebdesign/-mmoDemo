---
import { site } from "../data/site";
import MobileNav from "./MobileNav.astro";

const navLinks = [
  { href: "/", label: "Start" },
  { href: "/immobilien/", label: "Immobilien" },
  { href: "/leistungen/", label: "Leistungen" },
  { href: "/spezialisierungen/", label: "Spezialisierungen" },
  { href: "/ueber-uns/", label: "Über uns" },
  { href: "/kontakt/", label: "Kontakt" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 border-b border-line bg-paper/95 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex shrink-0 items-center gap-3">
      <span class="flex h-10 w-10 items-center justify-center border border-brass font-display text-xl text-brass-dark" aria-hidden="true">S</span>
      <span class="flex flex-col leading-tight">
        <span class="whitespace-nowrap font-display text-lg text-ink">SIM Immobilien</span>
        <span class="whitespace-nowrap text-[9px] uppercase tracking-[0.3em] text-slate">Service · Montabaur</span>
      </span>
    </a>

    <nav class="hidden items-center gap-5 lg:flex xl:gap-7" aria-label="Hauptnavigation">
      {navLinks.map((link) => {
        const active = link.href === "/" ? currentPath === "/" : currentPath.startsWith(link.href);
        return (
          <a
            href={link.href}
            class:list={[
              "whitespace-nowrap text-sm font-medium transition hover:text-brass",
              active ? "text-brass-dark" : "text-ink",
            ]}
            aria-current={active ? "page" : undefined}
          >
            {link.label}
          </a>
        );
      })}
    </nav>

    <div class="flex items-center gap-3 sm:gap-4">
      <a
        href={`tel:${site.phone.replace(/\s/g, "")}`}
        class="hidden items-center gap-2 whitespace-nowrap text-sm font-medium text-ink transition hover:text-brass lg:inline-flex"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="text-brass-dark" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
        {site.phoneHeader}
      </a>
      <a href="/kontakt/" class="btn btn-sm btn-dark hidden whitespace-nowrap sm:inline-flex">
        Erstberatung
      </a>
      <button
        id="mobile-nav-open"
        type="button"
        class="inline-flex items-center justify-center p-2 text-ink transition hover:text-brass lg:hidden"
        aria-label="Menü öffnen"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M4 7h16M4 12h16M4 17h16" stroke-linecap="round" />
        </svg>
      </button>
    </div>
  </div>
</header>

<MobileNav />

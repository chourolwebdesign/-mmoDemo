---
import Layout from "../../layouts/Layout.astro";
import GesucheBoard from "../../components/GesucheBoard.astro";
import SuchauftragForm from "../../components/SuchauftragForm.astro";
import { site } from "../../data/site";
---

<Layout
  title={`Kundengesuche & Suchauftrag | ${site.name}`}
  description={`Aktuelle Kundengesuche und Suchaufträge für Häuser, Wohnungen, Grundstücke und Gewerbeimmobilien in Wiesbaden und dem Rheingau — hinterlegen Sie Ihr eigenes Suchprofil bei ${site.name}.`}
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <p class="eyebrow">Gesuche</p>
    <h1 class="mt-1 font-display text-4xl text-ink">Kundengesuche</h1>
    <p class="mt-3 max-w-2xl text-slate">
      Hier finden Sie eine anonymisierte Auswahl aktueller Suchaufträge unserer
      Kund:innen. Bevor wir eine Immobilie öffentlich vermarkten, prüfen wir sie
      zunächst gegen diese Kartei — gute Objekte finden so oft einen Käufer, ohne
      je auf einem Portal zu erscheinen.
    </p>

    <div class="mt-10">
      <GesucheBoard />
    </div>
  </section>

  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <SuchauftragForm />
  </section>
</Layout>

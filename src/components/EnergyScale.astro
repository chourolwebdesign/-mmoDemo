---
interface Props {
  typ: "verbrauch" | "bedarf";
  wert: number;
  klasse: string;
  energietraeger: string;
  baujahr: number;
  gueltigBis: string;
}

const { typ, wert, klasse, energietraeger, baujahr, gueltigBis } = Astro.props;

const bands: { klasse: string; color: string; max: number }[] = [
  { klasse: "A+", color: "#0a8a3f", max: 30 },
  { klasse: "A", color: "#3fa535", max: 50 },
  { klasse: "B", color: "#8bc53f", max: 75 },
  { klasse: "C", color: "#c8d63f", max: 100 },
  { klasse: "D", color: "#f4e13f", max: 130 },
  { klasse: "E", color: "#f2b73f", max: 160 },
  { klasse: "F", color: "#ee8c3f", max: 200 },
  { klasse: "G", color: "#e75c3f", max: 250 },
  { klasse: "H", color: "#d1263f", max: 999 },
];

const gueltigDate = new Date(gueltigBis).toLocaleDateString("de-DE", { year: "numeric", month: "long" });
const markerPercent = Math.min(96, Math.max(4, (wert / 260) * 100));
---

<div class="rounded-2xl border border-line bg-white p-5">
  <p class="eyebrow">Energieausweis</p>
  <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-3 text-sm">
    <div>
      <dt class="text-slate">Typ</dt>
      <dd class="font-medium text-ink">{typ === "verbrauch" ? "Verbrauchsausweis" : "Bedarfsausweis"}</dd>
    </div>
    <div>
      <dt class="text-slate">Endenergieverbrauch</dt>
      <dd class="font-medium tabular-nums text-ink">{wert} kWh/(m²·a)</dd>
    </div>
    <div>
      <dt class="text-slate">Energieträger</dt>
      <dd class="font-medium text-ink">{energietraeger}</dd>
    </div>
    <div>
      <dt class="text-slate">Baujahr lt. Ausweis</dt>
      <dd class="font-medium tabular-nums text-ink">{baujahr}</dd>
    </div>
  </dl>
  <p class="mt-1 text-xs text-slate">Gültig bis {gueltigDate}</p>

  <div class="relative mt-5">
    <div class="flex h-8 overflow-hidden rounded-md">
      {bands.map((band) => (
        <div
          class:list={["flex flex-1 items-center justify-center text-xs font-bold text-white/90", band.klasse === klasse && "ring-2 ring-inset ring-ink"]}
          style={{ backgroundColor: band.color }}
        >
          {band.klasse}
        </div>
      ))}
    </div>
    <div class="absolute -top-2 flex flex-col items-center" style={{ left: `${markerPercent}%`, transform: "translateX(-50%)" }}>
      <span class="rounded bg-ink px-1.5 py-0.5 text-[10px] font-bold text-white">{wert}</span>
      <span class="mt-0.5 h-3 w-0.5 bg-ink"></span>
    </div>
  </div>
</div>
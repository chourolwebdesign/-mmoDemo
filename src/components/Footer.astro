---
import { site, regionen } from "../data/site";

const navigation = [
  { href: "/", label: "Start" },
  { href: "/immobilien/", label: "Immobilien" },
  { href: "/leistungen/", label: "Leistungen" },
  { href: "/spezialisierungen/", label: "Spezialisierungen" },
  { href: "/wertermittlung/", label: "Wertermittlung" },
  { href: "/suchauftrag/", label: "Gesuche" },
  { href: "/ueber-uns/", label: "Über uns" },
  { href: "/kontakt/", label: "Kontakt" },
];

const seoLinks = [
  { href: "/immobilien/?vermarktungsart=kauf&objektart=haus", label: "Haus kaufen in Montabaur" },
  { href: "/immobilien/?vermarktungsart=kauf&objektart=wohnung", label: "Wohnung kaufen im Westerwald" },
  { href: "/immobilien/?vermarktungsart=miete&objektart=wohnung", label: "Wohnung mieten in Limburg" },
  { href: "/immobilien/?objektart=grundstueck", label: "Baugrundstück im Westerwaldkreis" },
  { href: "/verkaufen/", label: "Immobilie verkaufen in Montabaur" },
  { href: "/wertermittlung/", label: "Immobilienbewertung Westerwald" },
];
---

<footer class="border-t border-line bg-ink text-white/90">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-4">
      <div>
        <div class="flex items-center gap-3">
          <span class="flex h-10 w-10 items-center justify-center border border-brass font-display text-xl text-brass" aria-hidden="true">S</span>
          <p class="font-display text-lg text-white">{site.name}</p>
        </div>
        <p class="mt-4 text-sm leading-relaxed text-white/70">{site.tagline}</p>
        <div class="mt-5 flex gap-3">
          <a href={site.instagram} target="_blank" rel="noopener noreferrer" class="border border-white/20 p-2 transition hover:border-brass hover:text-brass" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
          </a>
          <a href={site.facebook} target="_blank" rel="noopener noreferrer" class="border border-white/20 p-2 transition hover:border-brass hover:text-brass" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9.5c0-.3.2-.5.5-.5Z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <p class="eyebrow text-brass">Navigation</p>
        <ul class="mt-4 space-y-2 text-sm">
          {navigation.map((link) => (
            <li><a href={link.href} class="text-white/70 hover:text-brass">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div>
        <p class="eyebrow text-brass">Kontakt</p>
        <ul class="mt-4 space-y-3 text-sm text-white/70">
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-brass"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            {site.street}, {site.zip} {site.city}
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-brass"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92Z"/></svg>
            <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:text-brass">{site.phoneNote}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-brass"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 6L22 7"/></svg>
            <a href={`mailto:${site.email}`} class="hover:text-brass">{site.email}</a>
          </li>
          <li class="flex items-start gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" class="mt-0.5 shrink-0 text-brass"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            {site.hours}
          </li>
        </ul>
      </div>

      <div>
        <p class="eyebrow text-brass">Das könnte Sie interessieren</p>
        <ul class="mt-4 space-y-2 text-sm">
          {seoLinks.map((link) => (
            <li><a href={link.href} class="text-white/70 hover:text-brass">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 border-t border-white/10 pt-6">
      <p class="eyebrow text-brass">Regionen</p>
      <p class="mt-3 text-sm leading-relaxed text-white/60">
        {regionen.join(" · ")}
      </p>
    </div>

    <div class="mt-8 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {site.name}. Alle Rechte vorbehalten. {site.credit}</p>
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Rechtliches">
        <a href="/impressum/" class="hover:text-brass">Impressum</a>
        <a href="/datenschutz/" class="hover:text-brass">Datenschutz</a>
        <button id="footer-cookie-settings" type="button" class="hover:text-brass">Cookie-Einstellungen</button>
        <a href="#top" class="hover:text-brass">Nach oben</a>
      </nav>
    </div>
  </div>
</footer>

<script>
  document.getElementById("footer-cookie-settings")?.addEventListener("click", () => {
    localStorage.removeItem("cookie-consent");
    document.getElementById("cookie-consent")?.classList.remove("hidden");
  });
</script>

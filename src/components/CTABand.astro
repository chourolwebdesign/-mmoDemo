---
interface Props {
  title: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  title,
  text,
  ctaLabel = "Jetzt kontaktieren",
  ctaHref = "/kontakt/",
} = Astro.props;
---

<section class="bg-ink text-white">
  <div class="mx-auto flex max-w-6xl flex-col items-start gap-6 px-4 py-16 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
    <div class="max-w-2xl">
      <h2 class="font-display text-3xl leading-tight sm:text-4xl">{title}</h2>
      {text && <p class="mt-3 text-white/75">{text}</p>}
    </div>
    <a href={ctaHref} class="shrink-0 rounded-full bg-brass px-7 py-3.5 text-sm font-semibold text-ink transition hover:bg-white">
      {ctaLabel}
    </a>
  </div>
</section>

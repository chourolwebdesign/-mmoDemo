---
import { site } from "../data/site";

const seoLinks = [
  { href: "/immobilien/?vermarktungsart=kauf&objektart=haus", label: "Haus kaufen in Wiesbaden" },
  { href: "/immobilien/?vermarktungsart=kauf&objektart=wohnung", label: "Wohnung kaufen in Wiesbaden" },
  { href: "/immobilien/?vermarktungsart=miete&objektart=wohnung", label: "Wohnung mieten in Mainz" },
  { href: "/immobilien/?objektart=grundstueck", label: "Baugrundstück im Rheingau" },
  { href: "/verkaufen/", label: "Immobilie verkaufen in Wiesbaden" },
  { href: "/suchauftrag/", label: "Suchauftrag hinterlegen" },
];
---

<footer class="border-t border-line bg-ink text-white/90">
  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <div class="grid gap-10 lg:grid-cols-4">
      <div>
        <p class="font-display text-xl text-white">{site.name}</p>
        <p class="mt-3 text-sm leading-relaxed text-white/70">
          {site.street}<br />
          {site.zip} {site.city}
        </p>
        <p class="mt-3 text-sm text-white/70">
          <a href={`tel:${site.phone.replace(/\s/g, "")}`} class="hover:text-brass">{site.phoneDisplay}</a><br />
          <a href={`mailto:${site.email}`} class="hover:text-brass">{site.email}</a>
        </p>
        <p class="mt-3 text-sm text-white/70">{site.hours}</p>
        <div class="mt-5 flex gap-3">
          <a href={site.instagram} target="_blank" rel="noopener noreferrer" class="rounded-full border border-white/20 p-2 transition hover:border-brass hover:text-brass" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1"/></svg>
          </a>
          <a href={site.facebook} target="_blank" rel="noopener noreferrer" class="rounded-full border border-white/20 p-2 transition hover:border-brass hover:text-brass" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 9h3V6h-3c-1.7 0-3 1.3-3 3v2H9v3h2v6h3v-6h2.5l.5-3H14V9.5c0-.3.2-.5.5-.5Z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <p class="eyebrow text-white/50">Immobilien</p>
        <ul class="mt-4 space-y-2 text-sm">
          <li><a href="/immobilien/" class="text-white/70 hover:text-brass">Alle Angebote</a></li>
          <li><a href="/verkaufen/" class="text-white/70 hover:text-brass">Verkaufen</a></li>
          <li><a href="/suchauftrag/" class="text-white/70 hover:text-brass">Gesuche</a></li>
          <li><a href="/ueber-uns/" class="text-white/70 hover:text-brass">Über uns</a></li>
          <li><a href="/kontakt/" class="text-white/70 hover:text-brass">Kontakt</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <p class="eyebrow text-white/50">Das könnte Sie auch interessieren</p>
        <ul class="mt-4 grid gap-2 text-sm sm:grid-cols-2">
          {seoLinks.map((link) => (
            <li><a href={link.href} class="text-white/70 hover:text-brass">{link.label}</a></li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 flex flex-col gap-4 border-t border-white/10 pt-6 text-xs text-white/50 sm:flex-row sm:items-center sm:justify-between">
      <p>&copy; {new Date().getFullYear()} {site.name}. Alle Rechte vorbehalten. {site.credit}</p>
      <nav class="flex flex-wrap gap-x-5 gap-y-2" aria-label="Rechtliches">
        <a href="/impressum/" class="hover:text-brass">Impressum</a>
        <a href="/datenschutz/" class="hover:text-brass">Datenschutz</a>
        <button id="footer-cookie-settings" type="button" class="hover:text-brass">Cookie-Einstellungen</button>
        <a href="#top" class="hover:text-brass">Nach oben</a>
      </nav>
    </div>
  </div>
</footer>

<script>
  document.getElementById("footer-cookie-settings")?.addEventListener("click", () => {
    localStorage.removeItem("cookie-consent");
    document.getElementById("cookie-consent")?.classList.remove("hidden");
  });
</script>

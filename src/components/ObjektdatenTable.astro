---
import type { CollectionEntry } from "astro:content";
import { objektartLabels, formatNumber, priceLabel } from "../lib/format";

interface Props {
  entry: CollectionEntry<"immobilien">;
}

const { entry } = Astro.props;
const d = entry.data;

const rows: [string, string][] = [
  ["Objekt-ID", d.objektId],
  ["Objekttyp", objektartLabels[d.objektart]],
  ["Adresse", `${d.plz} ${d.ort}`],
];

if (d.wohneinheiten) rows.push(["Wohneinheiten", String(d.wohneinheiten)]);
if (d.wohnflaeche) rows.push(["Wohnfläche ca.", `${formatNumber(d.wohnflaeche)} m²`]);
if (d.nutzflaeche) rows.push(["Nutzfläche ca.", `${formatNumber(d.nutzflaeche)} m²`]);
if (d.grundstueck) rows.push(["Grundstück ca.", `${formatNumber(d.grundstueck)} m²`]);
if (d.zimmer) rows.push(["Zimmer", String(d.zimmer)]);
if (d.baujahr) rows.push(["Baujahr", String(d.baujahr)]);
if (d.verfuegbarAb) rows.push(["Verfügbar ab", d.verfuegbarAb]);
rows.push([d.vermarktungsart === "miete" ? "Kaltmiete" : "Kaufpreis", priceLabel(d.vermarktungsart, d.preis, d.preisAufAnfrage)]);
if (d.nebenkosten) rows.push(["Nebenkosten", d.nebenkosten]);
if (d.courtage) rows.push(["Courtage", d.courtage]);
---

<dl class="divide-y divide-line border border-line bg-white">
  {rows.map(([label, value]) => (
    <div class="flex items-baseline justify-between gap-4 px-5 py-3 text-sm">
      <dt class="text-slate">{label}</dt>
      <dd class="text-right font-medium tabular-nums text-ink">{value}</dd>
    </div>
  ))}
</dl>

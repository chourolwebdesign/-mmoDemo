---
---

<form
  id="hero-search"
  action="/immobilien/"
  method="get"
  class="grid gap-3 rounded-2xl bg-white/95 p-4 shadow-xl backdrop-blur sm:grid-cols-[1fr_1fr_1.3fr_auto] sm:p-5"
>
  <div class="flex flex-col gap-1">
    <label for="hs-vermarktungsart" class="text-xs font-medium text-slate">Kaufen / Mieten</label>
    <select id="hs-vermarktungsart" name="vermarktungsart" class="rounded-lg border border-line bg-white px-3 py-2 text-sm text-ink">
      <option value="">Beides</option>
      <option value="kauf">Kaufen</option>
      <option value="miete">Mieten</option>
    </select>
  </div>
  <div class="flex flex-col gap-1">
    <label for="hs-objektart" class="text-xs font-medium text-slate">Objektart</label>
    <select id="hs-objektart" name="objektart" class="rounded-lg border border-line bg-white px-3 py-2 text-sm text-ink">
      <option value="">Alle</option>
      <option value="haus">Haus</option>
      <option value="wohnung">Wohnung</option>
      <option value="grundstueck">Grundstück</option>
      <option value="gewerbe">Gewerbe</option>
    </select>
  </div>
  <div class="flex flex-col gap-1">
    <label for="hs-ort" class="text-xs font-medium text-slate">Ort</label>
    <input id="hs-ort" name="ort" type="text" placeholder="Montabaur, Wirges, Limburg …" class="rounded-lg border border-line bg-white px-3 py-2 text-sm text-ink placeholder:text-slate/60" />
  </div>
  <div class="flex items-end">
    <button type="submit" class="w-full rounded-lg bg-brass px-5 py-2.5 text-sm font-semibold text-ink transition hover:bg-brass-dark hover:text-white sm:w-auto">
      Suchen
    </button>
  </div>
</form>

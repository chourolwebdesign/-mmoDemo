---
const pillars = [
  { title: "Inhabergeführt", text: "Kurze Wege, klare Entscheidungen" },
  { title: "Regional verwurzelt", text: "Westerwald · Koblenz · Limburg" },
  { title: "Diskret & ehrlich", text: "Auch in sensiblen Situationen" },
];
---

<section class="relative bg-ink">
  <div class="absolute inset-0 overflow-hidden">
    <img
      src="/images/site/hero.jpg"
      srcset="/images/site/hero-800.jpg 800w, /images/site/hero-1280.jpg 1280w, /images/site/hero.jpg 2000w"
      sizes="100vw"
      width="2000"
      height="1247"
      alt="Schloss Montabaur über dem abendlichen Westerwald"
      class="h-full w-full object-cover"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-ink/35 sm:hidden"></div>
    <div class="absolute inset-0 bg-gradient-to-r from-ink/90 via-ink/55 to-ink/25"></div>
    <div class="absolute inset-x-0 bottom-0 h-40 bg-gradient-to-t from-ink/90 to-transparent"></div>
  </div>

  <div class="relative mx-auto flex min-h-[70vh] max-w-6xl flex-col justify-between px-4 pb-10 pt-16 sm:min-h-[82vh] sm:px-6 sm:pt-32">
    <div class="max-w-2xl">
      <p class="eyebrow text-brass">Immobilien · Verwaltung · Objektservice</p>
      <h1 class="mt-4 font-display text-4xl leading-[1.08] text-white sm:text-5xl lg:text-6xl">
        Immobilien mit Vertrauen.<br />
        <em class="font-normal text-brass-soft">Persönlich betreut</em> aus Montabaur.
      </h1>
      <p class="mt-6 max-w-md text-base leading-relaxed text-white/85">
        Wir sind kein klassischer Makler. Wir sind Ihr langfristiger
        Ansprechpartner rund um Ihre Immobilie — vom ersten Gespräch bis weit
        über den Abschluss hinaus.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/wertermittlung/#bewertung" class="btn btn-brass">
          Immobilie kostenlos bewerten <span aria-hidden="true">↗</span>
        </a>
        <a href="/kontakt/" class="btn btn-outline-light">
          Kostenlose Erstberatung
        </a>
      </div>
    </div>

    <div class="mt-12 grid gap-4 border-t border-white/15 pt-6 sm:mt-16 sm:gap-6 sm:pt-8 sm:grid-cols-3">
      {pillars.map((p) => (
        <div class="flex items-baseline gap-3 sm:block">
          <p class="font-display text-base text-white sm:text-lg">{p.title}</p>
          <p class="text-xs text-white/65 sm:mt-1 sm:text-sm">{p.text}</p>
        </div>
      ))}
    </div>
  </div>
</section>

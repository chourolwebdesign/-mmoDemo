---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  ctaLabel?: string;
  ctaHref?: string;
}

const {
  eyebrow = "Kostenlose Erstberatung",
  title,
  text,
  ctaLabel = "Termin vereinbaren",
  ctaHref = "/kontakt/",
} = Astro.props;
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
  <div class="bg-ink px-6 py-14 text-white sm:px-12">
    <div class="flex flex-col items-start gap-8 lg:flex-row lg:items-center lg:justify-between">
      <div class="max-w-2xl">
        <p class="eyebrow text-brass">{eyebrow}</p>
        <h2 class="mt-3 font-display text-3xl leading-tight sm:text-4xl">{title}</h2>
        {text && <p class="mt-4 text-white/75 leading-relaxed">{text}</p>}
      </div>
      <a href={ctaHref} class="btn btn-outline-brass shrink-0">
        {ctaLabel} <span aria-hidden="true">↗</span>
      </a>
    </div>
  </div>
</section>

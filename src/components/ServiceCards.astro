---
const services = [
  {
    title: "Verkauf & Vermietung",
    text: "Von der Wertermittlung über die Vermarktung bis zum Notartermin — mit geprüfter Interessentenkartei und diskreter Vermarktung.",
    href: "/verkaufen/",
    cta: "Mehr zum Verkauf",
    icon: "M3 9.5 12 3l9 6.5V21a1 1 0 0 1-1 1h-5v-7H9v7H4a1 1 0 0 1-1-1V9.5Z",
  },
  {
    title: "Wertermittlung",
    text: "Fundierte Markteinschätzung statt anonymer Online-Schätzung — auf Basis realer Vergleichsdaten aus dem Westerwald.",
    href: "/wertermittlung/",
    cta: "Mehr zur Wertermittlung",
    icon: "M9 3v18M15 3v18M3 9h18M3 15h18",
  },
  {
    title: "Verwaltung & Objektservice",
    text: "Wir kümmern uns um Ihre Immobilie, auch wenn Sie nicht vor Ort sind — von der Vermietung bis zur laufenden Betreuung.",
    href: "/kontakt/",
    cta: "Erstberatung anfragen",
    icon: "M12 2 4 6v6c0 5 3.4 8.6 8 10 4.6-1.4 8-5 8-10V6l-8-4Z",
  },
  {
    title: "Suchservice",
    text: "Sie suchen statt zu verkaufen? Hinterlegen Sie Ihr Suchprofil — viele passende Objekte werden nie öffentlich inseriert.",
    href: "/suchauftrag/",
    cta: "Suchauftrag hinterlegen",
    icon: "M11 4a7 7 0 1 0 0 14 7 7 0 0 0 0-14ZM21 21l-4.3-4.3",
  },
];
---

<section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
    {services.map((s) => (
      <div class="flex flex-col border border-line bg-white p-6">
        <span class="inline-flex h-11 w-11 items-center justify-center rounded-full bg-brass-soft text-brass-dark">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d={s.icon} stroke-linecap="round" stroke-linejoin="round" /></svg>
        </span>
        <h3 class="mt-4 font-display text-xl text-ink">{s.title}</h3>
        <p class="mt-2 flex-1 text-sm leading-relaxed text-slate">{s.text}</p>
        <a href={s.href} class="mt-4 inline-flex items-center gap-1 text-sm font-medium text-brass-dark hover:text-ink">
          {s.cta} <span aria-hidden="true">→</span>
        </a>
      </div>
    ))}
  </div>
</section>

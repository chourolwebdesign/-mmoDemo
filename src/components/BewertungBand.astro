---
const punkte = ["Kostenlos & unverbindlich", "Mit Vor-Ort-Termin", "Diskret — auch in sensiblen Situationen"];
---

<section class="bg-brass">
  <div class="mx-auto flex max-w-6xl flex-col gap-8 px-4 py-14 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
    <div class="max-w-2xl">
      <p class="text-[11px] font-semibold uppercase tracking-[0.2em] text-ink/70">
        Kostenlose Wertermittlung
      </p>
      <h2 class="mt-3 font-display text-3xl leading-tight text-ink sm:text-4xl">
        Was ist Ihre Immobilie wert?
      </h2>
      <p class="mt-3 max-w-xl text-ink/80 leading-relaxed">
        Die meisten Eigentümer starten genau hier: mit einer ehrlichen
        Einschätzung, was die eigene Immobilie heute wirklich wert ist —
        bevor irgendetwas entschieden wird.
      </p>
      <ul class="mt-5 flex flex-wrap gap-x-6 gap-y-2">
        {punkte.map((p) => (
          <li class="flex items-center gap-2 text-sm font-medium text-ink">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" class="shrink-0"><path d="m5 13 4 4L19 7" stroke-linecap="round" stroke-linejoin="round" /></svg>
            {p}
          </li>
        ))}
      </ul>
    </div>
    <div class="flex shrink-0 flex-col gap-3">
      <a href="/wertermittlung/#bewertung" class="btn btn-dark">
        Jetzt kostenlos bewerten lassen <span aria-hidden="true">↗</span>
      </a>
      <a href="/kontakt/" class="btn border border-ink/40 text-ink hover:border-ink hover:bg-ink hover:text-white">
        Kostenloses Erstgespräch
      </a>
    </div>
  </div>
</section>

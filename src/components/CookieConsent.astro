---
---

<div
  id="cookie-consent"
  class="fixed inset-x-0 bottom-0 z-50 hidden border-t border-line bg-paper/98 p-4 shadow-[0_-4px_24px_rgba(0,0,0,0.08)] backdrop-blur sm:p-6"
  role="dialog"
  aria-live="polite"
  aria-label="Cookie-Hinweis"
>
  <div class="mx-auto flex max-w-6xl flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
    <p class="text-sm text-slate">
      Wir verwenden nur technisch notwendige Cookies sowie optional eine Kartenanzeige
      (Google Maps), die erst nach Ihrer Zustimmung geladen wird. Details finden Sie in
      unserer <a href="/datenschutz/" class="underline decoration-brass underline-offset-2 hover:text-ink">Datenschutzerklärung</a>.
    </p>
    <div class="flex shrink-0 gap-3">
      <button
        id="cookie-decline"
        type="button"
        class="rounded-full border border-line px-4 py-2 text-sm font-medium text-slate transition hover:border-ink hover:text-ink"
      >
        Nur notwendige
      </button>
      <button
        id="cookie-accept"
        type="button"
        class="rounded-full bg-ink px-5 py-2 text-sm font-medium text-white transition hover:bg-brass"
      >
        Alle akzeptieren
      </button>
    </div>
  </div>
</div>

<script>
  const KEY = "cookie-consent";
  const banner = document.getElementById("cookie-consent");

  function getConsent(): string | null {
    return localStorage.getItem(KEY);
  }

  function setConsent(value: "all" | "necessary") {
    localStorage.setItem(KEY, value);
    document.dispatchEvent(new CustomEvent("cookie-consent-change", { detail: value }));
    banner?.classList.add("hidden");
  }

  if (!getConsent() && banner) {
    banner.classList.remove("hidden");
  }

  document.getElementById("cookie-accept")?.addEventListener("click", () => setConsent("all"));
  document.getElementById("cookie-decline")?.addEventListener("click", () => setConsent("necessary"));
</script>
